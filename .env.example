# CloudBase 配置（复制此文件为 .env 并填入实际值）
# 注意：VITE_ 前缀的环境变量会被打包进浏览器 bundle，所有访问者可见。
# CloudBase accessKey 是设计上可公开的客户端 key（类似 Firebase apiKey），
# 权限由 CloudBase Auth + 数据库安全规则控制，而非依赖此 key 保密。
# ⚠️ 切勿在此填入服务端密钥（如 TCB_SECRET_ID / TCB_SECRET_KEY）。
VITE_CLOUDBASE_ENV_ID=your-env-id
VITE_CLOUDBASE_REGION=ap-shanghai
VITE_CLOUDBASE_ACCESS_KEY=your-access-key

# Sentry 错误监控（可选，未配置则跳过初始化）
VITE_SENTRY_DSN=
