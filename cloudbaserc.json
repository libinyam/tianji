{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "envId": "tianji-d3gozv3qr802e49cb",
  "functionRoot": "cloudfunctions",
  "functions": [
    { "name": "content-actions", "handler": "index.main", "timeout": 20, "ignore": ["*.test.js"] },
    { "name": "content-moderation", "handler": "index.main", "timeout": 20, "ignore": ["*.test.js"] },
    { "name": "user-admin", "handler": "index.main", "timeout": 20, "ignore": ["*.test.js"] },
    { "name": "admin-delete", "handler": "index.main", "timeout": 20, "ignore": ["*.test.js"] },
    { "name": "check-admin", "handler": "index.main", "timeout": 20, "ignore": ["*.test.js"] },
    { "name": "ai-bot", "handler": "index.main", "timeout": 60, "ignore": ["*.test.js"] },
    { "name": "db-backup", "handler": "index.main", "timeout": 60, "ignore": ["*.test.js"] },
    { "name": "manage-announcements", "handler": "index.main", "timeout": 20, "ignore": ["*.test.js"] }
  ],
  "hosting": {
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Content-Type", "value": "text/html; charset=utf-8" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
        ]
      }
    ]
  }
}
